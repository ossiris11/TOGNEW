{
  "name": "togoshol-landing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:server": "tsx server/src/server.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:check-migration": "node scripts/check-migration.mjs",
    "db:push": "tsx server/prisma/apply-schema.ts",
    "db:seed": "prisma db seed",
    "build": "tsc -b && tsc -p tsconfig.server.json && vite build && node scripts/prerender.mjs",
    "lint": "eslint .",
    "test": "tsx --test tests/**/*.test.ts",
    "test:e2e": "playwright test",
    "smoke:prod": "node scripts/production-smoke.mjs",
    "monitor:uptime": "node scripts/uptime-alert.mjs",
    "backup:check": "node scripts/backup-restore-check.mjs",
    "import:vk": "node scripts/import-vk-market.mjs",
    "preview": "vite preview",
    "start": "node server/dist/server.js",
    "start:prod": "NODE_ENV=production node server/dist/server.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^6.19.3",
    "fastify": "^5.8.5",
    "framer-motion": "^12.41.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "lucide-react": "^1.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prisma": "^6.19.3",
    "puppeteer": "^25.2.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.0.0"
  }
}
